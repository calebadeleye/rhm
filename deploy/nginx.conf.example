# Example Nginx server block for Redemption Hour Radio.
# - Serves the built frontend (dist/) as static files
# - Reverse-proxies /api to the Express backend managed by PM2 (default port 4000)
#
# Copy to /etc/nginx/sites-available/redemptionradio.conf and symlink into
# sites-enabled, then `nginx -t && systemctl reload nginx`.

server {
    listen 80;
    listen [::]:80;
    server_name redemptionradio.example.com;

    # Redirect all HTTP to HTTPS once a certificate is issued (e.g. via certbot).
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name redemptionradio.example.com;

    ssl_certificate     /etc/letsencrypt/live/redemptionradio.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/redemptionradio.example.com/privkey.pem;

    root /var/www/redemptionradio/dist;
    index index.html;

    gzip on;
    gzip_types text/css application/javascript application/json image/svg+xml;

    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Static assets: long cache, filenames are content-hashed by Vite.
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # API — proxy to the Express backend (PM2-managed, listening on 4000).
    location /api/ {
        proxy_pass http://127.0.0.1:4000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 15s;
        proxy_connect_timeout 5s;
    }

    # SPA fallback: client-side routing (React Router) handles the rest.
    location / {
        try_files $uri $uri/ /index.html;
    }
}
