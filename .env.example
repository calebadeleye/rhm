# ---------------------------------------------------------------------------
# Backend (server/) — never prefixed with VITE_, never sent to the browser
# ---------------------------------------------------------------------------
AZURACAST_BASE_URL=https://radio.example.com
AZURACAST_STATION_SHORTCODE=redemption_radio
AZURACAST_API_KEY=

# Port the Express backend listens on.
PORT=4000
NODE_ENV=production

# Comma-separated list of origins allowed to call the API (CORS).
ALLOWED_ORIGINS=https://redemptionradio.example.com

# Optional: where contact form notifications should be forwarded, if you
# wire up outbound email later. Submissions are always stored server-side
# regardless of this value.
CONTACT_RECIPIENT_EMAIL=

# ---------------------------------------------------------------------------
# Frontend (src/) — VITE_ variables are public and bundled into the client.
# Never put secrets (like AZURACAST_API_KEY) behind a VITE_ prefix.
# ---------------------------------------------------------------------------
VITE_SITE_URL=https://redemptionradio.example.com
VITE_CONTACT_EMAIL=
VITE_CONTACT_PHONE=
VITE_DONATION_URL=
VITE_PRAYER_REQUEST_URL=
VITE_FACEBOOK_URL=
VITE_INSTAGRAM_URL=
VITE_YOUTUBE_URL=
VITE_X_URL=

# The API base path the frontend calls (proxied by Nginx/Apache to the
# Express backend in production; defaults to the Vite dev proxy in dev).
VITE_API_BASE=/api

# IANA timezone the station broadcasts from. Used only to label schedule
# times; all displayed times are converted to each visitor's local timezone.
VITE_STATION_TIMEZONE=America/New_York
